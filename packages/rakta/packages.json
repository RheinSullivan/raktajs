{
  "name": "rakta",
  "version": "0.1.0",
  "description": "Rakta.js core framework package for React, Bun, TypeScript, app routing, rendering, SEO, components, RPC, store, schema, HTTP, and auto imports.",
  "type": "module",
  "license": "MIT",
  "author": "Rhein Sullivan | Vyagra Nexus",
  "homepage": "https://raktajs.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/RheinSullivan/raktajs.git",
    "directory": "packages/rakta"
  },
  "bugs": {
    "url": "https://github.com/RheinSullivan/raktajs/issues"
  },
  "keywords": [
    "rakta",
    "rakta.js",
    "rheinsullivan",
    "framework",
    "react",
    "bun",
    "typescript",
    "router",
    "app-router",
    "seo",
    "ssr",
    "ssg",
    "csr",
    "fullstack",
    "rpc",
    "store",
    "schema",
    "http",
    "auto-import"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "rakta": "./dist/cli/rakta.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "import": "./dist/router/index.js"
    },
    "./seo": {
      "types": "./dist/seo/index.d.ts",
      "import": "./dist/seo/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./render": {
      "types": "./dist/render/index.d.ts",
      "import": "./dist/render/index.js"
    },
    "./forge": {
      "types": "./dist/forge/index.d.ts",
      "import": "./dist/forge/index.js"
    },
    "./tide": {
      "types": "./dist/tide/index.d.ts",
      "import": "./dist/tide/index.js"
    },
    "./rpc": {
      "types": "./dist/rpc/index.d.ts",
      "import": "./dist/rpc/index.js"
    },
    "./store": {
      "types": "./dist/store/index.d.ts",
      "import": "./dist/store/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js"
    },
    "./auto-import": {
      "types": "./dist/auto-import/index.d.ts",
      "import": "./dist/auto-import/index.js"
    }
  },
  "scripts": {
    "dev": "bun run ./src/cli/rakta.ts dev",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --sourcemap=external && bun build ./src/cli/rakta.ts --outfile ./dist/cli/rakta.js --target bun --sourcemap=external",
    "typecheck": "tsc -p ./tsconfig.json --noEmit",
    "prepublishOnly": "bun run build && bun run typecheck"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  }
}