{
	"name": "raktajs",
	"version": "0.2.8",
	"description": "Rakta.js core framework package for React, Bun, TypeScript, app routing, rendering, SEO, components, RPC, store, schema, HTTP, PWA, and auto imports.",
	"type": "module",
	"license": "MIT",
	"author": "Rhein Sullivan | Vyagra Nexus™",
	"homepage": "https://raktajs.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/RheinSullivan/raktajs.git",
		"directory": "packages/rakta"
	},
	"bugs": {
		"url": "https://github.com/RheinSullivan/raktajs/issues"
	},
	"keywords": [
		"rakta",
		"rakta.js",
		"rheinsullivan",
		"framework",
		"react",
		"bun",
		"typescript",
		"router",
		"app-router",
		"seo",
		"ssr",
		"ssg",
		"csr",
		"fullstack",
		"rpc",
		"store",
		"schema",
		"http",
		"pwa",
		"offline",
		"auto-import",
		"plugin-system",
		"service-container"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"rakta": "dist/cli/rakta.js"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./components": {
			"types": "./dist/components/index.d.ts",
			"import": "./dist/components/index.js"
		},
		"./router": {
			"types": "./dist/router/index.d.ts",
			"import": "./dist/router/index.js"
		},
		"./seo": {
			"types": "./dist/seo/index.d.ts",
			"import": "./dist/seo/index.js"
		},
		"./config": {
			"types": "./dist/config/index.d.ts",
			"import": "./dist/config/index.js"
		},
		"./render": {
			"types": "./dist/render/index.d.ts",
			"import": "./dist/render/index.js"
		},
		"./forge": {
			"types": "./dist/forge/index.d.ts",
			"import": "./dist/forge/index.js"
		},
		"./tide": {
			"types": "./dist/tide/index.d.ts",
			"import": "./dist/tide/index.js"
		},
		"./rpc": {
			"types": "./dist/rpc/index.d.ts",
			"import": "./dist/rpc/index.js"
		},
		"./store": {
			"types": "./dist/store/index.d.ts",
			"import": "./dist/store/index.js"
		},
		"./schema": {
			"types": "./dist/schema/index.d.ts",
			"import": "./dist/schema/index.js"
		},
		"./http": {
			"types": "./dist/http/index.d.ts",
			"import": "./dist/http/index.js"
		},
		"./auto-import": {
			"types": "./dist/auto-import/index.d.ts",
			"import": "./dist/auto-import/index.js"
		},
		"./pwa": {
			"types": "./dist/pwa/index.d.ts",
			"import": "./dist/pwa/index.js"
		},
		"./kernel": {
			"types": "./dist/kernel/index.d.ts",
			"import": "./dist/kernel/index.js"
		},
		"./middleware": {
			"types": "./dist/middleware/index.d.ts",
			"import": "./dist/middleware/index.js"
		},
		"./docs": {
			"types": "./dist/docs/index.d.ts",
			"import": "./dist/docs/index.js"
		},
		"./hooks": {
			"types": "./dist/hooks/index.d.ts",
			"import": "./dist/hooks/index.js"
		},
		"./deployment": {
			"types": "./dist/deployment/index.d.ts",
			"import": "./dist/deployment/index.js"
		},
		"./layout": {
			"types": "./dist/layout/index.d.ts",
			"import": "./dist/layout/index.js"
		},
		"./data": {
			"types": "./dist/data/index.d.ts",
			"import": "./dist/data/index.js"
		},
		"./dx": {
			"types": "./dist/dx/index.d.ts",
			"import": "./dist/dx/index.js"
		},
		"./plugin": {
			"types": "./dist/plugin/index.d.ts",
			"import": "./dist/plugin/index.js"
		},
		"./testing": {
			"types": "./dist/testing/index.d.ts",
			"import": "./dist/testing/index.js"
		},
		"./performance": {
			"types": "./dist/performance/index.d.ts",
			"import": "./dist/performance/index.js"
		},
		"./security": {
			"types": "./dist/security/index.d.ts",
			"import": "./dist/security/index.js"
		},
		"./ops": {
			"types": "./dist/ops/index.d.ts",
			"import": "./dist/ops/index.js"
		}
	},
	"scripts": {
		"dev": "bun run ./src/cli/rakta.ts dev",
		"build": "bun run ./scripts/build.ts && tsc -p ./tsconfig.json --emitDeclarationOnly",
		"typecheck": "tsc -p ./tsconfig.json --noEmit && tsc -p ./scripts/tsconfig.json --noEmit",
		"prepublishOnly": "bun run build && bun run typecheck"
	},
	"peerDependencies": {
		"react": ">=19.0.0",
		"react-dom": ">=19.0.0"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/node": "^26.0.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"typescript": "^6.0.3"
	},
	"publishConfig": {
		"access": "public"
	}
}
