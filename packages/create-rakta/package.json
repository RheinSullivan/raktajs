{
	"name": "create-rakta-app",
	"version": "1.0.0",
	"description": "Create a fullstack Rakta.js application with frontend, backend, database, rendering mode, and CSS framework choices.",
	"type": "module",
	"license": "MIT",
	"author": "Rhein Sullivan | Vyagra Nexus™",
	"homepage": "https://raktajs.dev",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/RheinSullivan/raktajs.git",
		"directory": "packages/create-rakta"
	},
	"bugs": {
		"url": "https://github.com/RheinSullivan/raktajs/issues"
	},
	"keywords": [
		"rakta",
		"rakta.js",
		"rheinsullivan",
		"create-rakta-app",
		"vyagranexus",
		"framework",
		"frontend",
		"react",
		"bun",
		"typescript",
		"fullstack",
		"cli",
		"scaffold",
		"generator",
		"app-router",
		"gaman"
	],
	"publishConfig": {
		"access": "public"
	},
	"bin": {
		"create-rakta-app": "dist/index.js"
	},
	"files": [
		"dist",
		"assets",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"dev": "bun run ./src/index.ts",
		"build": "bun run ./scripts/build.ts",
		"typecheck": "tsc -p ./tsconfig.json --noEmit && tsc -p ./scripts/tsconfig.json --noEmit",
		"prepublishOnly": "bun run build && bun run typecheck"
	},
	"dependencies": {
		"@clack/prompts": "^1.6.0",
		"picocolors": "^1.1.1"
	},
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/node": "^26.0.1",
		"typescript": "^6.0.3"
	}
}
